# firmware.meta — Логика под чистый JE
main_loop:
 INT             # Печатает букву. Си сам сдвигает gpl_ip на букву (0x101)
 INC GPL_IP      # Сдвигаем gpl_ip на признак продолжения (0x102, где лежит 0)
 JE main_loop    # Проверяем memory[0x102]. Там 0! Условие выполнено -> прыгаем в начало!
 HLT             # Когда наткнемся на 1 (в конце) -> условие JE сорвется, и мы выйдем сюда