# firmware.meta — Линейный исполнитель
main_loop:
 INT             # Просто вызываем прерывание скорлупы для текущей ячейки
 INC GPL_IP      # Переходим к следующему байту программы
 JE main_loop    # Если мы перешли на ячейку, где лежит 0 -> возвращаемся в цикл
 HLT             # Если встретили не 0 (а в конце программы у нас HLT) -> стоп