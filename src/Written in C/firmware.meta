# firmware.meta — Микропрограмма (ядро) мета-процессора
# Исполняется C-скорлупой начиная с dsl_ip = 0

main_loop:
 INC [GPL_IP]    # Увеличиваем значение в текущей ячейке памяти прикладной программы
 INT             # Вызываем системное прерывание (вывод символа на экран)
 INC GPL_IP      # Сдвигаем указатель прикладной программы на следующий байт
 JE main_loop    # Если текущее значение в памяти стало 0 — прыгаем в начало цикла
 HLT             # Иначе останавливаем мета-процессор