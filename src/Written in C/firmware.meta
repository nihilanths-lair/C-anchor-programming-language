# stage0/firmware.meta — Прямой тест 64-битных регистров
start:
    mov rax, 79      # Загружаем 'O'
    sys_print        # Печатаем!
    
    mov rax, 75      # Загружаем 'K'
    sys_print        # Печатаем!
    
    mov rbx, 75      # Кладем в RBX тоже 75
    cmp rax, rbx     # Проверяем: 75 == 75? (ZF станет 1)
    
    je exit_program  # Если равны — прыгаем на выход
    hlt              # Сюда не дойдем

exit_program:
    hlt