# firmware.meta — Настоящее ПЗУ / BIOS нашей системы
bios_entry:
# 1. Считываем "регистр" AH прикладной программы (ячейка 0x100)
# Си-скорлупа стоит на 0x100. Там лежит число 1 (функция печати строки)
# Нам нужно проверить, что вызвана именно функция 1
# (Здесь микрокод прошивки считывает аргументы, проверяет их через JE)
# Если AH == 1, мы переходим к циклу печати строки:
print_string_loop:
 # Наша прошивка использует gpl_ip, чтобы прыгнуть на адрес строки msg (0x120)
 # Она временно переставляет gpl_ip на данные строки.
 INT                   # Дёргаем Си-скорлупу! Си видит маркер (если мы оставили putchar) и печатает букву
 INC GPL_IP            # Двигаем указатель по строке msg вперед
 # Проверяем терминальный нуль-символ (\0)
 JE exit_bios          # Если в строке msg наткнулись на 0 -> строка кончилась, выходим!
 JMP print_string_loop # Иначе крутимся в цикле и печатаем следующую букву

exit_bios:
 HLT                   # Возвращаем управление