// ============================================================================
// Спецификация Архитектуры Виртуальной Машины (ISA) — ЧАСТЬ 1
// Формат макроса: MACRO__IDENTIFICATION_OPKODES(имя, номер, размер, "описание")
// ============================================================================

// --- СИСТЕМНЫЕ И УПРАВЛЕНИЕ ПОТОКОМ (0, 12, 14, 15, 20, 21) ---
MACRO__IDENTIFICATION_OPKODES(HLT,     0,  1, "HLT: Останова процессора")
MACRO__IDENTIFICATION_OPKODES(JMP_I8, 12,  2, "JMP i8: Безусловный знаковый прыжок")
MACRO__IDENTIFICATION_OPKODES(JE_I8,  14,  2, "JE i8: Прыжок, если равно (ZF == 1)")
MACRO__IDENTIFICATION_OPKODES(JNE_I8, 15,  2, "JNE i8: Прыжок, если не равно (ZF == 0)")
MACRO__IDENTIFICATION_OPKODES(CALL_I8,20,  2, "CALL i8: Вызов процедуры")
MACRO__IDENTIFICATION_OPKODES(RET,    21,  1, "RET: Возврат из процедуры")

// --- ПЕРЕСЫЛКА ДАННЫХ И РЕГИСТРЫ (1 - 4) ---
MACRO__IDENTIFICATION_OPKODES(MOV_A_I8, 1,  2, "MOV a8, i8: Загрузить константу в a8")
MACRO__IDENTIFICATION_OPKODES(MOV_B_I8, 2,  2, "MOV b8, i8: Загрузить константу в b8")
MACRO__IDENTIFICATION_OPKODES(MOV_A_B,  3,  1, "MOV a8, b8: Скопировать b8 в a8")
MACRO__IDENTIFICATION_OPKODES(MOV_B_A,  4,  1, "MOV b8, a8: Скопировать a8 в b8")

// --- БИНАРНАЯ И УНАРНАЯ АРИФМЕТИКА (5 - 11) ---
MACRO__IDENTIFICATION_OPKODES(ADD_A_I8, 5,  2, "ADD a8, i8: Сложить a8 с константой")
MACRO__IDENTIFICATION_OPKODES(SUB_A_I8, 6,  2, "SUB a8, i8: Вычесть константу из a8")
MACRO__IDENTIFICATION_OPKODES(MUL_A_I8, 7,  2, "MUL a8, i8: Умножить a8 на константу")
MACRO__IDENTIFICATION_OPKODES(DIV_A_I8, 8,  2, "DIV a8, i8: Разделить a8 на константу (с защитой)")
MACRO__IDENTIFICATION_OPKODES(RSUB_A_I8,9,  2, "RSUB a8, i8: Обратное вычитание (i8 - a8)")
MACRO__IDENTIFICATION_OPKODES(RDIV_A_I8,10, 2, "RDIV a8, i8: Обратное деление (i8 / a8 с защитой)")
MACRO__IDENTIFICATION_OPKODES(NEG_A8,  11,  1, "NEG a8: Поменять знак аккумулятора")

// --- ЛОГИКА СРАВНЕНИЯ И МОДИФИКАЦИЯ РЕГИСТРОВ (13, 16, 17) ---
MACRO__IDENTIFICATION_OPKODES(CMP_A_I8,13,  2, "CMP a8, i8: Знаковое сравнение a8 с константой")
MACRO__IDENTIFICATION_OPKODES(INC_A8,  16,  1, "INC a8: Инкремент регистра a8")
MACRO__IDENTIFICATION_OPKODES(DEC_A8,  17,  1, "DEC a8: Декремент регистра a8")

// --- УПРАВЛЕНИЕ СТЕКОМ (18, 19) ---
MACRO__IDENTIFICATION_OPKODES(PUSH_A8, 18,  1, "PUSH a8: Положить a8 в стек")
MACRO__IDENTIFICATION_OPKODES(POP_A8,  19,  1, "POP a8: Снять из стека в a8")

// --- ИНДЕКСНАЯ АДРЕСАЦИЯ И ПАМЯТЬ (22 - 27) ---
MACRO__IDENTIFICATION_OPKODES(MOV_SI_I8,22, 2, "MOV si, i8: Направить SI на адрес памяти")
MACRO__IDENTIFICATION_OPKODES(MOV_DI_I8,23, 2, "MOV di, i8: Направить DI на адрес памяти")
MACRO__IDENTIFICATION_OPKODES(LD_A_MSI, 24,  1, "LD a8, [si]: Косвенное чтение из источника")
MACRO__IDENTIFICATION_OPKODES(ST_MDI_A, 25,  1, "ST [di], a8: Косвенная запись в приемник")
MACRO__IDENTIFICATION_OPKODES(INC_SI,  26,  1, "INC si: Продвижение источника вперед")
MACRO__IDENTIFICATION_OPKODES(INC_DI,  27,  1, "INC di: Продвижение приемника вперед")