# program.meta — Наша первая полноценная x86 программа на одном RIP
start:
    mov rax, 79      # Загружаем ASCII код буквы 'O' (79) прямо в RAX
    sys_print        # Вызываем системную печать!
    
    mov rbx, 4       # Загружаем число 4 в RBX
    mov rax, 71      # Загружаем число 71 в RAX
    add rax, rbx     # Настоящая математика Intel: 71 + 4 = 75 (ASCII код буквы 'K'!)
    
    sys_print        # Печатаем результат вычислений (букву 'K')!
    hlt              # Чистая, штатная остановка процессора!