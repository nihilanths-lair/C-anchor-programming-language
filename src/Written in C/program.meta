# program.meta — Полноценный x86-цикл на новых регистрах
start:
    mov rax, 90      # RAX = 90 (ASCII-код буквы 'Z'). Это наш стартовый символ.
    mov rbx, 1       # RBX = 1. Шаг, который мы будем вычитать на каждой итерации.
    mov rcx, 64      # RCX = 64. Граница остановки (буква 'A' — это 65, значит на 64 выходим).

loop_start:
    sys_print        # Печатаем текущий символ из RAX
    sub rax, rbx     # RAX = RAX - RBX (уменьшаем код буквы на 1)
    # Теперь проверяем, не дошли ли мы до конца.
    # Сравниваем текущее значение RAX с нашей границей в RCX.
    # Так как в базовом наборе у нас cmp проверяет только RAX и RBX, 
    # нам нужно временно перекинуть границу из RCX в RBX!
    mov rbx, rcx     # Теперь в RBX лежит 64
    cmp rax, rbx     # Сравниваем текущую букву с 64
    # Возвращаем в RBX единицу для следующего шага вычитания
    mov rbx, 1
    jne loop_start   # Если RAX еще НЕ равен 64 — прыгаем в начало цикла!
    hlt              # Чистый, штатный останов процессора!