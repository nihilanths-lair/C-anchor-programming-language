# program.meta — Настоящий ассемблерный код в стиле BIOS

# --- СЕКЦИЯ КОДА ---
start:
 # Имитируем загрузку аргументов в "виртуальные регистры". 
 # Пусть ячейка памяти 0x0150 будет регистром AH (номер функции),
 # а ячейка 0x0151 — указателем на строку (адрес метки msg).

 DATA 1          # AH = 1 (функция BIOS "вывод строки")
 DATA 0x01       # Старший байт адреса строки msg (0x0120)
 DATA 0x20       # Младший байт адреса строки msg

 INT             # Вызываем прерывание мета-процессора!
 HLT             # Всё, завершаем прикладную программу

# --- СЕКЦИЯ ДАННЫХ ---
# Размещаем сырые байты по канону: метка, тип (DATA/db), данные и 0
msg:
 DATA 79         # 'O'
 DATA 75         # 'K'
 DATA 0          # Терминальный нуль-символ (\0)