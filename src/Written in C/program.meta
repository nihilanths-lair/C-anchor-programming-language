# program.meta — Настоящий, ультра-быстрый нативный цикл
start:
    mov rax, 90      # RAX = 90 ('Z')
    mov rbx, 64      # RBX = 64 (Граница остановки)

loop_start:
    sys_print        # Печатаем символ
    
    dec rax          # Уменьшаем RAX на 1 (переходим к следующей букве)
    
    cmp rax, rbx     # Сравниваем текущую букву с границей 64 в безопасном RBX
    jne loop_start   # Если еще не 64 — прыгаем в начало!

    hlt              # Конец программы!