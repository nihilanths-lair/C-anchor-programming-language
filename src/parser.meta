mov rax, 1
mov rcx, 15
mov rsi, rcx

; --- НАЧАЛО ЦИКЛА (ячейка 5) ---
mov rcx, [rsi]
cmp rcx, 0
je_rel 4          ; Исправлено: прыжок на 4 ячейки вперед (на hlt)

syscall
inc rsi
jmp_rel -9        ; Исправлено: прыжок на 9 ячейки назад (на начало цикла)

hlt

