mov rax, 1
mov rcx, my_string ; Автоподстановка абсолютного адреса строки!
mov rsi, rcx

start_loop:
mov rcx, [rsi]
cmp rcx, 0
je_rel exit_loop   ; Автоматический расчет смещения вперед!

syscall
inc rsi
jmp_rel start_loop ; Автоматический расчет смещения назад!

exit_loop:
hlt

my_string:         ; Метка указывает прямо на первую букву данных
104                ; 'h'
101                ; 'e'
108                ; 'l'
108                ; 'l'
111                ; 'o'
0                  ; Конец строки