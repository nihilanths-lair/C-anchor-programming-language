mov rax, 1
mov rcx, my_string 
mov rsi, rcx

start_loop:
mov rcx, [rsi]
cmp rcx, 0
je_rel exit_loop   

syscall
inc rsi
jmp_rel start_loop 

exit_loop:
hlt

; --- СЕКЦИЯ ДАННЫХ В КЛАССИЧЕСКОМ СИНТАКСИСЕ ---
my_string:
db "hello", 0       ; Препроцессор сам развернет строку в ячейки памяти и допишет ноль!