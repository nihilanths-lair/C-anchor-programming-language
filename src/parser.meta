mov rax, 1           ; 0:
mov rcx, my_string   ; 2:
mov rsi, rcx         ; 4:

start_loop:
 mov rcx, [rsi]      ; 6:
 cmp rcx, 0          ; 8:
 je_rel exit_loop    ; 10:

 syscall             ; 11:
 inc rsi             ; 12:
 jmp_rel start_loop  ; 14:

exit_loop:
 hlt                 ; 16:


my_string:
 db "hello", 0       ; 17: