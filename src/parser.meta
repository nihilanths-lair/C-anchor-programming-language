; --- Инициализация перед циклом ---
mov rax, 1        ; Настраиваем RAX на функцию вывода SYSCALL
mov rcx, 15       ; Адрес, где начинается наша текстовая строка "hello" (подсчитаем ниже)
mov rsi, rcx      ; Переносим этот адрес в курсор RSI

; --- НАЧАЛО ЦИКЛА (Адрес этой команды в памяти процессора будет равен 6) ---
mov rcx, [rsi]    ; Читаем текущий символ из памяти по адресу RSI в регистр RCX
cmp rcx, 0        ; Проверяем: это конец строки (ноль)?
je_rel 6          ; Если ZF=1 (встретили 0), прыгаем на 6 ячеек вперед (прямо на hlt)

; --- Тело цикла (печать и сдвиг курсора) ---
syscall           ; Печатаем символ, который лежит в RCX
add rcx, 1        ; Упс! У нас нет команды ADD RSI. Мы временно берем адрес из RSI...
mov rcx, rsi      ; ...копируем в RCX...
add rcx, 1        ; ...прибавляем 1 к адресу...
mov rsi, rcx      ; ...и возвращаем обновленный адрес обратно в RSI!

jmp_rel -16       ; Прыгаем на 16 ячеек НАЗАД (ровно на начало цикла, к команде mov rcx, [rsi])

hlt               ; Сюда нас перебросит команда je_rel 6, когда строка закончится

; --- ТЕКСТОВЫЕ ДАННЫЕ ДЛЯ СКАНИРОВАНИЯ (Адрес первой буквы равен 15) ---
104               ; 'h'
101               ; 'e'
108               ; 'l'
108               ; 'l'
111               ; 'o'
0                 ; Конец строки (маркер терминатора)