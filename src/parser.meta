mov rax, 1
mov rcx, 11       ; Точный адрес начала строки "hello" (пересчитай сам!)
mov rsi, rcx

; --- НАЧАЛО ЦИКЛА ---
mov rcx, [rsi]
cmp rcx, 0
je_rel 5          ; Если встретили 0, прыгаем вперед на hlt

syscall           ; Печатаем символ
inc rsi           ; Инкремент курсора текста! (Всего одна короткая команда вместо трех!)
jmp_rel -6        ; Точный прыжок назад на начало цикла (mov rcx, [rsi])

hlt

; --- ДАННЫЕ ---
104               ; 'h'
101               ; 'e'
108               ; 'l'
108               ; 'l'
111               ; 'o'
0                 ; Конец строки