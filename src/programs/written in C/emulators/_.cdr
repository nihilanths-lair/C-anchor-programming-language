-----------------------------------------------------------------
<Python>
# Это однострочный комментарий
print("Результат сложения:", 5 + 3) # Выведет 8

"""
Это многострочный комментарий
(точнее, многострочная строка, 
которую используют как комментарий)
"""
print("Умножение:", 10 * 2) # Выведет 20
-----------------------------------------------------------------
-----------------------------------------------------------------
<Lua>
-- Это однострочный комментарий (двойное тире)
print("Сложение:", 10 + 5) -- Выведет 15

--[[
  Это многострочный комментарий.
  Он начинается с --[[ и 
  заканчивается двумя квадратными скобками.
]]
print("Умножение и скобки:", (2 + 2) * 5) -- Выведет 20

-- Особенность Lua: возведение в степень через оператор ^
print("2 в 3-й степени:", 2 ^ 3) -- Выведет 8
-----------------------------------------------------------------
